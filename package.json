{
  "name": "stream-notifications-discord-bot",
  "version": "1.5.1",
  "description": "Discord bot that announces configured Twitch live streams and YouTube uploads.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev:frontend": "vite --config frontend/vite.config.js",
    "build:frontend": "vite build --config frontend/vite.config.js",
    "check": "node --check src/index.js && npm run build:frontend"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "discord.js": "^14.26.2",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.7.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^5.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "apexcharts": "^5.10.6",
    "react": "^18.3.1",
    "react-apexcharts": "^2.1.0",
    "react-custom-scrollbars-2": "^4.5.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "react-select": "^5.10.2",
    "uuid": "^14.0.0",
    "vite": "^5.4.21"
  }
}
