DISCORD_TOKEN=your_discord_bot_token

# Use either TWITCH_ACCESS_TOKEN or the TWITCH_CLIENT_ID/TWITCH_CLIENT_SECRET pair.
TWITCH_ACCESS_TOKEN=your_twitch_access_token
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Optional
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3000
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_password
SESSION_SECRET=change_this_to_a_long_random_value
EVENTSUB_ENABLED=true

# Used only to seed the dashboard config on first run.
DISCORD_CHANNEL_ID=your_discord_channel_id
TWITCH_USER_LOGINS=
DISCORD_ROLE_ID=
POLL_INTERVAL_SECONDS=60
CONFIG_FILE=./data/dashboard-config.json
STATE_FILE=./data/live-state.json
STATUS_FILE=./data/live-status.json
HISTORY_FILE=./data/history.json
ERROR_FILE=./data/errors.json
